# Home Assistant connection (required for deploy --restart and dashboard push)
HA_URL=http://homeassistant.local:8123
HA_TOKEN=your-long-lived-access-token-here

# Config volume mount point (macOS SMB share)
HA_CONFIG_MOUNT=/Volumes/config

# Optional: auto-mount via osascript (macOS only)
# Set this to enable automatic mounting when the share is disconnected.
# Must be mounted manually once first so macOS caches credentials in Keychain.
HA_CONFIG_SMB_URL=smb://user@homeassistant.local/config

# Dashboard URL path (must already exist as storage-mode dashboard in HA)
HA_DASHBOARD_URL_PATH=rain-warner

# Test location (used by pytest for live DWD tests)
# Get from your HA: Developer Tools → Template → {{ state_attr('zone.home', 'latitude') }}
LATITUDE=49.45
LONGITUDE=11.08
